export interface ReturnOrderDetails {
    id:                   string;
    orderNumber:          string;
    returnOrderNumber:    string;
    totalPrice:           number;
    discount:             number;
    shippingCost:         number;
    vatRate:              number;
    vatAmount:            number;
    totalOrderAmount:     number;
    clientReason:         string;
    adminReason:          null;
    deliveryDate:         Date;
    returnDate:           Date;
    status:               string;
    address:              Address;
    orderItems:           OrderItem[];
    orderStatusHistories: OrderStatusHistory[];
}

export interface Address {
    id:          string;
    name:        string;
    latitude:    number;
    longitude:   number;
    description: string;
    isDefault:   boolean;
    userId:      string;
}

export interface OrderItem {
    id:                string;
    productName:       string;
    productImage:      string;
    unitOfMeasureName: string;
    quantity:          number;
    priceAtPurchase:   number;
    totalPrice:        number;
}

export interface OrderStatusHistory {
    id:           string;
    status:       string;
    creationTime: Date;
    orderId:      string;
}
